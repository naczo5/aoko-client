<Window x:Class="Aoko.WindowPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Inject"
        Width="560" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BgBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Custom Inject"
                   Foreground="{DynamicResource TextBrush}"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1"
                   Text="Select a window to inject into. JVM (java/javaw) processes are listed first."
                   Foreground="{DynamicResource DimTextBrush}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="2"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource SliderBgBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="4">
            <ListBox x:Name="WindowList"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource TextBrush}"
                     SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayLabel}" TextWrapping="Wrap" Margin="4,2">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsJvm}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Button Grid.Row="3"
                x:Name="RefreshButton"
                Content="Refresh list"
                Style="{StaticResource DarkButton}"
                HorizontalAlignment="Left"
                Margin="0,10,0,0"
                Padding="12,6"
                Click="RefreshButton_Click"/>

        <DockPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock Text="Bridge version"
                       Foreground="{DynamicResource TextBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"
                       Margin="0,0,10,0"/>
            <ComboBox x:Name="VersionCombo"
                      Style="{StaticResource DarkComboBox}"
                      Width="160"
                      HorizontalAlignment="Left">
                <ComboBoxItem Content="Auto-detect" Tag="auto" IsSelected="True"/>
                <ComboBoxItem Content="1.8.9" Tag="1.8.9"/>
                <ComboBoxItem Content="1.21" Tag="1.21"/>
                <ComboBoxItem Content="26.1" Tag="26.1"/>
                <ComboBoxItem Content="26.2" Tag="26.2"/>
            </ComboBox>
        </DockPanel>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource DarkButton}"
                    Width="90"
                    Margin="0,0,8,0"
                    Padding="12,6"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
            <Button Content="Inject"
                    Style="{StaticResource DarkButton}"
                    Width="90"
                    Padding="12,6"
                    IsDefault="True"
                    Click="InjectButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
